CompileFlags:
  CompilationDatabase: .build-stm32h563vit6x-debug
---
If:
  PathMatch: (^|.*/).*\.(cc|cpp|cxx|hh|hpp|hxx)$
CompileFlags:
    Add: [-std=c++20]
---
If:
  PathMatch: (^|.*/).*\.(cc|cpp|cxx|hh|hpp|hxx)$
CompileFlags:
  Add:
    - -isystem
    - /usr/arm-none-eabi/include/c++/14.2.0
    - -isystem
    - /usr/arm-none-eabi/include/c++/14.2.0/arm-none-eabi
    - -isystem
    - /usr/arm-none-eabi/include/c++/14.2.0/backward
    - -isystem
    - /usr/lib/gcc/arm-none-eabi/14.2.0/include-fixed
    - -isystem
    - /usr/arm-none-eabi/include
---
If:
  PathMatch: (^|.*/)lib/drivers/instances/stm32h5xx/.*
CompileFlags:
  CompilationDatabase: .build-stm32h563vit6x-debug
---
If:
  PathMatch: (^|.*/)instances/stm32/.*
CompileFlags:
  CompilationDatabase: .build-stm32h563vit6x-debug
